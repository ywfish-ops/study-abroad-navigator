  "_gemini_prompt_template": {
    "instruction": "以下是院校数据 schema，请按照此结构填写指定学校的 batch_b 字段。数据来源：学校官网招生页面。不确定的字段填 null，不要猜测。",
    "fields_to_fill": [
      "programs（主要本科专业，最多10个，英文）",
      "ielts_min（最低总分，数字，无要求填 null）",
      "toefl_min（最低总分，数字，无要求填 null）",
      "english_note（补充说明，如单科要求）",
      "avg_accepted_ielts（录取者平均分，官网有则填，否则 null）",
      "application_deadline.early_action（早申截止，YYYY-MM-DD，无则 null）",
      "application_deadline.regular（常规截止，YYYY-MM-DD）",
      "sat_mid50（中间50%分数段，如 {math:[700,780], reading:[680,750]}，无则 null）",
      "financial_aid_international（是否向国际生提供助学金，true/false）",
      "scholarship_availability（是否有奖学金，true/false）",
      "scholarship_note（奖学金名称及简介，100字以内）",
      "scholarship_typical_usd_annual（典型年奖学金金额 USD，估算，无则 null）"
    ],
    "output_format": "严格 JSON，字段名与 schema 一致，不添加额外字段"
  }
}
